@import "tailwindcss";

/* â”€â”€â”€ VARIABLES ORIGINALES (mismo que yankoacuna.cl) â”€â”€â”€â”€â”€â”€â”€ */
:root {
    --bg-primary: #0d1117;
    --bg-secondary: #161b22;
    --bg-card: #1c2230;
    --bg-card-hover: #212a3e;
    --accent: #5c9aff;
    --accent-glow: rgba(92, 154, 255, 0.25);
    --accent-2: #b599ff;
    --green: #48cf5b;
    --orange: #f59b58;
    --red: #ff6a63;
    --cyan: #4bf069;
    --text-primary: #f0f6fc;
    --text-secondary: #b0b8c4;
    --text-muted: #9da6b3;
    --border: rgba(255, 255, 255, 0.08);
    --border-hover: rgba(79, 142, 247, 0.6);
    --radius: 14px;
    --shadow: 0 8px 32px rgba(0, 0, 0, 0.35);
    --bg-nav: rgba(13, 17, 23, 0.85);

    /* Tailwind Interop */
    --color-primary: var(--bg-primary);
    --color-accent: var(--accent);
    --color-text-primary: var(--text-primary);
    --color-text-secondary: var(--text-secondary);
}

.light-theme {
    --bg-primary: #f8faff;
    --bg-secondary: #ffffff;
    --bg-card: #ffffff;
    --bg-card-hover: #f0f4ff;
    --accent: #2563eb;
    --accent-glow: rgba(37, 99, 235, 0.1);
    --accent-2: #8b5cf6;
    --green: #22c55e;
    --orange: #f97316;
    --red: #ef4444;
    --cyan: #06b6d4;
    --text-primary: #1e293b;
    --text-secondary: #475569;
    --text-muted: #64748b;
    --border: rgba(0, 0, 0, 0.08);
    --border-hover: rgba(37, 99, 235, 0.4);
    --shadow: 0 8px 32px rgba(37, 99, 235, 0.08);
    --bg-nav: rgba(248, 250, 255, 0.85);
}

/* â”€â”€â”€ BASE â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
*,
*::before,
*::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

html {
    scroll-behavior: smooth;
    overflow-x: hidden;
}

body {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    background: var(--bg-primary);
    color: var(--text-primary);
    line-height: 1.65;
    font-size: 15px;
}

section {
    padding: 4rem 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
}

.container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
}

.section-title {
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
}

.section-title span {
    color: var(--accent);
}

.section-subtitle {
    color: var(--text-secondary);
    font-size: 0.95rem;
    margin-bottom: 3rem;
}

/* â”€â”€â”€ GLASSMORPHISM â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.glass {
    background: var(--bg-card);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--border);
    border-radius: var(--radius);
}

/* â”€â”€â”€ BG CANVAS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
#bg-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: -1;
    pointer-events: none;
    opacity: 0.6;
    transition: opacity 0.5s ease;
}

.light-theme #bg-canvas {
    opacity: 0.35;
}

/* â”€â”€â”€ NAV BAR â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.top-nav {
    position: sticky;
    top: 0;
    z-index: 998;
    background: var(--bg-nav, rgba(13, 17, 23, 0.85));
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.65rem 1.8rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.top-nav .nav-brand {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--text-primary);
    text-decoration: none;
    letter-spacing: -0.02em;
}

.top-nav .nav-brand span {
    color: var(--accent);
}

.nav-links {
    display: flex;
    gap: 0.2rem;
    list-style: none;
}

.nav-links a {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 0.35rem 0.9rem;
    border-radius: 6px;
    transition: all 0.18s;
}

.nav-links a:hover,
.nav-links a.active {
    color: var(--text-primary);
    background: var(--bg-card-hover);
}

.nav-links a.active {
    color: var(--accent);
    background: rgba(79, 142, 247, 0.1);
    font-weight: 700;
}

@media (max-width: 640px) {
    .nav-links {
        display: none;
    }

    .top-nav {
        padding: 0.6rem 1rem;
    }
}

/* â”€â”€â”€ LANG / THEME BUTTONS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.lang-btn {
    background: var(--bg-card);
    border: 1px solid var(--border);
    color: var(--text-primary);
    padding: 0.4rem 0.9rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
    font-family: inherit;
}

.lang-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
}

.theme-btn {
    background: var(--bg-card);
    border: 1px solid var(--border);
    color: var(--text-primary);
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    cursor: pointer;
    transition: all 0.2s;
    margin-left: 0.5rem;
}

.theme-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px var(--accent-glow);
}

/* â”€â”€â”€ HERO â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.hero {
    background: linear-gradient(135deg, var(--bg-primary) 0%, var(--bg-card) 60%, var(--bg-primary) 100%);
    border-bottom: 1px solid var(--border);
    padding: 5rem 2rem 4rem;
    text-align: center;
    position: relative;
    overflow: hidden;
}

.hero::before {
    content: '';
    position: absolute;
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(79, 142, 247, 0.12) 0%, transparent 65%);
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    border-radius: 50%;
    pointer-events: none;
}

.hero h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800;
    letter-spacing: -1px;
    background: linear-gradient(135deg, var(--text-primary) 30%, var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
}

.hero .subtitle {
    color: var(--accent);
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 1rem;
}

.hero p {
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto 2rem;
    font-size: 1rem;
}

.social-links {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
}

.social-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1.2rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--bg-secondary);
    color: var(--text-primary);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.2s;
}

.social-links a:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-glow);
}

.email-link {
    position: relative;
}

.copy-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 4px;
    background: var(--bg-card-hover);
    border: 1px solid var(--border);
    cursor: pointer;
    margin-left: 4px;
    transition: background 0.2s;
}

.copy-badge:hover {
    background: var(--accent-glow);
}

/* â”€â”€â”€ CV BUTTONS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.cv-links {
    display: flex;
    justify-content: center;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin-top: 1.2rem;
}

.cv-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 1.3rem;
    border-radius: 8px;
    border: 1px solid var(--accent);
    background: rgba(79, 142, 247, 0.1);
    color: var(--accent);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 700;
    transition: all 0.2s;
}

.cv-btn:hover {
    background: var(--accent);
    color: #fff;
}

/* â”€â”€â”€ CARD FOOTER â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.card-footer {
    margin-top: 1.1rem;
    padding-top: 0.9rem;
    border-top: 1px solid var(--border);
    display: flex;
    gap: 0.7rem;
    flex-wrap: wrap;
}

.card-footer a {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    transition: color 0.2s;
}

.card-footer a:hover {
    color: #7eb8ff;
}

/* â”€â”€â”€ FOOTER â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
footer {
    border-top: 1px solid var(--border);
    padding: 2rem 1.5rem;
    text-align: center;
    color: var(--text-muted);
    font-size: 0.82rem;
}

footer a {
    color: var(--accent);
    text-decoration: none;
}

/* â”€â”€â”€ EXPERIENCE TIMELINE â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.timeline {
    position: relative;
    padding-left: 2rem;
}

.timeline::before {
    content: '';
    position: absolute;
    left: 0.45rem;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--accent), transparent);
}

.tl-item {
    position: relative;
    margin-bottom: 2rem;
}

.tl-item::before {
    content: '';
    position: absolute;
    left: -1.63rem;
    top: 0.35rem;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent);
    border: 2px solid var(--bg-primary);
    box-shadow: 0 0 0 3px var(--accent-glow);
}

.tl-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin-bottom: 0.35rem;
}

.tl-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
}

.tl-company {
    font-size: 0.88rem;
    color: var(--accent);
    font-weight: 600;
    margin-bottom: 0.15rem;
}

.tl-date {
    font-size: 0.75rem;
    font-weight: 600;
    background: rgba(79, 142, 247, 0.12);
    border: 1px solid rgba(79, 142, 247, 0.3);
    color: var(--accent);
    padding: 2px 10px;
    border-radius: 20px;
    white-space: nowrap;
}

.tl-item ul {
    list-style: none;
    margin-top: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
}

.tl-item ul li {
    font-size: 0.85rem;
    color: var(--text-secondary);
    display: flex;
    align-items: flex-start;
    gap: 0.4rem;
}

.tl-item ul li::before {
    content: 'â–¸';
    color: var(--accent);
    font-size: 0.7rem;
    margin-top: 3px;
    flex-shrink: 0;
}

.tl-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.2rem 1.4rem;
    transition: border-color 0.2s, transform 0.2s;
}

.tl-card:hover {
    border-color: var(--border-hover);
}

.tl-card.clickable {
    cursor: pointer;
}

.tl-card.clickable:hover {
    transform: translateX(2px);
}

/* â”€â”€â”€ EDUCATION SPECIFIC â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.edu-content {
    margin-top: 0.8rem;
}

.edu-specialization {
    margin: 15px 0;
    padding: 12px;
    background: rgba(79, 142, 247, 0.05);
    border-left: 3px solid var(--accent);
    border-radius: 4px;
}

.edu-specialization-header {
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--accent);
    margin-bottom: 5px;
    display: flex;
    align-items: center;
    gap: 8px;
}

.edu-specialization p {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 0;
}

.edu-bullets {
    list-style: none;
    margin-top: 1rem;
    padding-left: 0;
}

.project-link-mini {
    display: inline-block;
    margin-left: 8px;
    font-size: 0.8rem;
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s;
}

.project-link-mini:hover {
    color: #7eb8ff;
}

/* â”€â”€â”€ PROJECT GRID â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 1.8rem;
}

.project-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s;
    box-shadow: var(--shadow);
}

.project-card:hover {
    transform: translateY(-4px);
    border-color: var(--border-hover);
    box-shadow: 0 12px 40px rgba(79, 142, 247, 0.15);
}

.project-image-wrap {
    position: relative;
    height: 200px;
    overflow: hidden;
    background: var(--bg-secondary);
}

.project-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    transition: transform 0.4s;
}

.project-card:hover .project-image-wrap img {
    transform: scale(1.04);
}

.project-image-wrap .badge-featured {
    position: absolute;
    top: 10px;
    left: 10px;
    color: white;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 20px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
}

.badge-industrial {
    background: #eab308;
    color: #1e1e1e !important;
}

.badge-research {
    background: #6b38c9;
    color: white !important;
}

.badge-academic {
    background: #3b82f6;
    color: white !important;
}

.badge-global {
    background: #0ea5e9;
    color: white !important;
}

/* â”€â”€â”€ CARD BODY â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.card-body {
    padding: 1.4rem;
    display: flex;
    flex-direction: column;
    flex: 1;
}

.card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 0.6rem;
    gap: 0.5rem;
}

.card-body h3 {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.3;
}

.card-context {
    font-size: 0.72rem;
    color: var(--text-muted);
    font-weight: 500;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 4px;
    padding: 2px 8px;
    white-space: nowrap;
    margin-top: 2px;
    flex-shrink: 0;
}

.card-body p.desc {
    color: var(--text-secondary);
    font-size: 0.875rem;
    line-height: 1.6;
    margin-bottom: 1rem;
}

.impact-line {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.6rem;
}

/* â”€â”€â”€ FEATURES â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.features {
    margin-bottom: 1rem;
}

.features ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
}

.features ul li {
    font-size: 0.82rem;
    color: var(--text-secondary);
    display: flex;
    align-items: flex-start;
    gap: 0.4rem;
}

.features ul li::before {
    content: 'â–¸';
    color: var(--accent);
    font-size: 0.7rem;
    margin-top: 3px;
    flex-shrink: 0;
}

/* â”€â”€â”€ TECH TAGS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.tech-section {
    margin-top: auto;
    padding-top: 0.5rem;
}

.tech-group {
    margin-bottom: 0.5rem;
}

.tech-group-label {
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 0.3rem;
}

.tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.3rem;
}

.tag {
    font-size: 0.72rem;
    font-weight: 600;
    padding: 3px 9px;
    border-radius: 20px;
    letter-spacing: 0.02em;
}

.tag-frontend {
    background: rgba(56, 189, 248, 0.12);
    color: #38bdf8;
    border: 1px solid rgba(56, 189, 248, 0.25);
}

.tag-backend {
    background: rgba(74, 222, 128, 0.12);
    color: #4ade80;
    border: 1px solid rgba(74, 222, 128, 0.25);
}

.tag-db {
    background: rgba(251, 146, 60, 0.12);
    color: #fb923c;
    border: 1px solid rgba(251, 146, 60, 0.25);
}

.tag-infra {
    background: rgba(167, 139, 250, 0.12);
    color: #a78bfa;
    border: 1px solid rgba(167, 139, 250, 0.25);
}

.tag-ml {
    background: rgba(249, 115, 22, 0.12);
    color: #fb923c;
    border: 1px solid rgba(249, 115, 22, 0.25);
}

.tag-other {
    background: rgba(255, 255, 255, 0.07);
    color: var(--text-secondary);
    border: 1px solid var(--border);
}

/* â”€â”€â”€ PROJECT FILTERS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.project-filters {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
}

.filter-btn {
    padding: 0.5rem 1.2rem;
    border-radius: 20px;
    border: 1px solid var(--border);
    background: var(--bg-secondary);
    color: var(--text-secondary);
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    font-family: inherit;
}

.filter-btn:hover {
    border-color: var(--accent);
    color: var(--text-primary);
    background: var(--accent-glow);
}

.filter-btn.active {
    background: var(--accent);
    color: #051633;
    border-color: var(--accent);
    box-shadow: 0 0 15px var(--accent-glow);
    font-weight: 800;
}

/* â”€â”€â”€ HIDDEN PROJECTS (Ver mÃ¡s) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.hidden-projects {
    display: none;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 1.8rem;
    margin-top: 1.8rem;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
}

.hidden-projects.show {
    display: grid;
    opacity: 1;
    transform: translateY(0);
}

/* â”€â”€â”€ STACK COMPLETO BUTTON â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.btn-detalles {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 0.7rem;
    margin: 1rem 0;
    background: rgba(255, 255, 255, 0.03);
    border: 1px dashed var(--border);
    border-radius: 8px;
    color: var(--text-secondary);
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: inherit;
}

.btn-detalles:hover {
    background: rgba(79, 142, 247, 0.05);
    border-color: var(--accent);
    color: var(--accent);
}

.btn-detalles.active {
    background: var(--bg-secondary);
    border-style: solid;
    color: var(--accent);
}

/* â”€â”€â”€ LOAD MORE â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.load-more-container {
    display: flex;
    justify-content: center;
    margin-top: 2.5rem;
}

.btn-load-more {
    padding: 0.8rem 2.5rem;
    border-radius: 8px;
    background: transparent;
    border: 1px solid var(--accent);
    color: var(--accent);
    font-weight: 700;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
}

.btn-load-more:hover {
    background: var(--accent);
    color: #ffffff;
    box-shadow: 0 5px 15px var(--accent-glow);
    transform: translateY(-2px);
}

/* â”€â”€â”€ PROJECT HIGHLIGHT (scrollToProject) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
@keyframes pulse-highlight {
    0% {
        transform: scale(1);
        box-shadow: 0 0 0 0 rgba(79, 142, 247, 0.7);
    }

    30% {
        transform: scale(1.03);
        box-shadow: 0 0 30px rgba(79, 142, 247, 0.4);
        border-color: var(--accent);
    }

    100% {
        transform: scale(1);
        box-shadow: 0 0 0 0 rgba(79, 142, 247, 0);
    }
}

.project-highlight {
    animation: pulse-highlight 2s ease-out;
}

/* â”€â”€â”€ SKILLS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.2rem;
}

.tech-category {
    margin-bottom: 2.2rem;
}

.tech-category-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: 1rem;
    border-left: 3px solid var(--accent);
    padding-left: 0.6rem;
}

.tech-icon-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
}

.tech-icon-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.45rem;
    padding: 0.9rem 0.7rem;
    width: 88px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    cursor: default;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
    text-align: center;
}

.tech-icon-card:hover {
    transform: translateY(-4px);
    border-color: var(--border-hover);
    box-shadow: 0 8px 24px rgba(79, 142, 247, 0.15);
}

.tech-icon-card img {
    width: 36px;
    height: 36px;
    object-fit: contain;
}

.tech-icon-card span {
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--text-secondary);
    line-height: 1.2;
}

/* â”€â”€â”€ CONTACT FORM â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.contact-container {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 2rem 1rem;
    margin-top: 1rem;
}

.contact-glass-card {
    background: rgba(28, 34, 48, 0.4);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2.5rem;
    width: 100%;
    max-width: 600px;
    box-shadow: var(--shadow);
    transition: transform 0.3s ease, border-color 0.3s ease;
}

.contact-glass-card:hover {
    border-color: var(--border-hover);
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4), 0 0 20px var(--accent-glow);
}

.contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}

.form-group {
    position: relative;
    width: 100%;
}

.form-group input,
.form-group textarea {
    width: 100%;
    padding: 1.2rem 1rem;
    background: rgba(13, 17, 23, 0.6);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text-primary);
    font-size: 1rem;
    font-family: inherit;
    outline: none;
    transition: all 0.3s ease;
    resize: vertical;
}

.form-group textarea::-webkit-scrollbar {
    width: 8px;
}

.form-group textarea::-webkit-scrollbar-thumb {
    background: var(--border-hover);
    border-radius: 4px;
}

.form-group label {
    position: absolute;
    top: 1.2rem;
    left: 1.2rem;
    color: var(--text-muted);
    font-size: 1rem;
    pointer-events: none;
    transition: all 0.2s ease;
    background: transparent;
    padding: 0 0.2rem;
}

.form-group input:focus,
.form-group textarea:focus,
.form-group input:not(:placeholder-shown),
.form-group textarea:not(:placeholder-shown) {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent);
}

.form-group input:focus+label,
.form-group textarea:focus+label,
.form-group input:not(:placeholder-shown)+label,
.form-group textarea:not(:placeholder-shown)+label {
    top: -0.6rem;
    left: 0.8rem;
    font-size: 0.8rem;
    color: var(--accent);
    background: var(--bg-primary);
    border-radius: 4px;
}

.input-highlight {
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 2px;
    background: var(--accent);
    transition: width 0.3s ease, left 0.3s ease;
    border-radius: 0 0 8px 8px;
}

.form-group input:focus~.input-highlight,
.form-group textarea:focus~.input-highlight {
    width: 100%;
    left: 0;
}

.contact-submit-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    padding: 1rem 2rem;
    border-radius: 8px;
    border: none;
    background: var(--accent);
    color: #fff;
    font-size: 1.05rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px var(--accent-glow);
    margin-top: 0.5rem;
    font-family: inherit;
    width: 100%;
}

.contact-submit-btn:hover {
    background: #3a75d1;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(92, 154, 255, 0.4);
}

.contact-submit-btn svg {
    transition: transform 0.3s ease;
}

.contact-submit-btn:hover svg {
    transform: translate(3px, -3px) scale(1.1);
}

.contact-submit-btn:active {
    transform: translateY(0);
}

@media (max-width: 768px) {
    .contact-glass-card {
        padding: 1.5rem;
    }
}

/* â”€â”€â”€ SECTION TITULAR (Contacto) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.section-titular {
    text-align: center;
    margin-bottom: 2rem;
}

.section-titular h2 {
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
}

.section-titular h2 span {
    color: var(--accent);
}

/* â”€â”€â”€ GLOBE SECTION â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.globe-layout {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    flex-wrap: wrap;
    justify-content: center;
}

#globe-container {
    flex-shrink: 0;
    width: 480px;
    height: 480px;
    max-width: 100%;
    border-radius: 50%;
    overflow: hidden;
    cursor: grab;
    box-shadow: 0 0 60px rgba(79, 142, 247, 0.2);
}

#globe-container:active {
    cursor: grabbing;
}

.globe-sidebar {
    flex: 1;
    min-width: 240px;
}

.globe-legend-title {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 1.2rem;
}

.globe-location-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem 1.2rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg-card);
    margin-bottom: 0.8rem;
    cursor: pointer;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
}

.globe-location-card:hover,
.globe-location-card.active {
    border-color: var(--border-hover);
    transform: translateX(4px);
    box-shadow: 0 4px 20px rgba(79, 142, 247, 0.12);
}

.globe-loc-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    margin-top: 4px;
    flex-shrink: 0;
    box-shadow: 0 0 8px currentColor;
}

.globe-loc-name {
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.3rem;
}

.globe-loc-roles {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
}

.globe-loc-roles span {
    font-size: 0.78rem;
    color: var(--text-secondary);
}

@media (max-width: 640px) {
    #globe-container {
        width: 320px;
        height: 320px;
    }
}

/* â”€â”€â”€ IANKO CHAT â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.chat-btn-floating {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--accent);
    color: white;
    box-shadow: 0 4px 30px var(--accent-glow);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 1001;
    transition: all 0.3s;
    border: none;
}

.chat-btn-floating:hover {
    transform: scale(1.1);
    box-shadow: 0 8px 40px var(--accent-glow);
}

/* â”€â”€â”€ LIGHT THEME OVERRIDES â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
.light-theme .form-group input,
.light-theme .form-group textarea {
    background: rgba(255, 255, 255, 0.8);
    color: var(--text-primary);
}

.light-theme .contact-glass-card {
    background: rgba(255, 255, 255, 0.7);
}

.light-theme .form-group input:focus+label,
.light-theme .form-group textarea:focus+label,
.light-theme .form-group input:not(:placeholder-shown)+label,
.light-theme .form-group textarea:not(:placeholder-shown)+label {
    background: var(--bg-primary);
}

/* â”€â”€â”€ RESPONSIVE â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
@media (max-width: 768px) {
    .project-grid {
        grid-template-columns: 1fr;
    }

    .hidden-projects {
        grid-template-columns: 1fr;
    }
}
␀
␀/␀*␀ ␀␀%␀%␀% ␀T␀E␀R␀M␀I␀N␀A␀L␀ ␀␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀%␀% ␀*␀/␀
␀.␀t␀e␀r␀m␀i␀n␀a␀l␀-␀f␀l␀o␀a␀t␀i␀n␀g␀-␀b␀t␀n␀ ␀{␀
␀ ␀ ␀ ␀ ␀p␀o␀s␀i␀t␀i␀o␀n␀:␀ ␀f␀i␀x␀e␀d␀;␀
␀ ␀ ␀ ␀ ␀b␀o␀t␀t␀o␀m␀:␀ ␀7␀r␀e␀m␀;␀
␀ ␀ ␀ ␀ ␀r␀i␀g␀h␀t␀:␀ ␀1␀.␀5␀r␀e␀m␀;␀
␀ ␀ ␀ ␀ ␀w␀i␀d␀t␀h␀:␀ ␀5␀0␀p␀x␀;␀
␀ ␀ ␀ ␀ ␀h␀e␀i␀g␀h␀t␀:␀ ␀5␀0␀p␀x␀;␀
␀ ␀ ␀ ␀ ␀b␀o␀r␀d␀e␀r␀-␀r␀a␀d␀i␀u␀s␀:␀ ␀5␀0␀%␀;␀
␀ ␀ ␀ ␀ ␀b␀a␀c␀k␀g␀r␀o␀u␀n␀d␀:␀ ␀v␀a␀r␀(␀-␀-␀a␀c␀c␀e␀n␀t␀)␀;␀
␀ ␀ ␀ ␀ ␀c␀o␀l␀o␀r␀:␀ ␀#␀f␀f␀f␀;␀
␀ ␀ ␀ ␀ ␀b␀o␀r␀d␀e␀r␀:␀ ␀n␀o␀n␀e␀;␀
␀ ␀ ␀ ␀ ␀b␀o␀x␀-␀s␀h␀a␀d␀o␀w␀:␀ ␀0␀ ␀4␀p␀x␀ ␀2␀0␀p␀x␀ ␀r␀g␀b␀a␀(␀7␀9␀,␀ ␀1␀4␀2␀,␀ ␀2␀4␀7␀,␀ ␀0␀.␀4␀)␀;␀
␀ ␀ ␀ ␀ ␀c␀u␀r␀s␀o␀r␀:␀ ␀p␀o␀i␀n␀t␀e␀r␀;␀
␀ ␀ ␀ ␀ ␀z␀-␀i␀n␀d␀e␀x␀:␀ ␀1␀0␀0␀0␀;␀
␀ ␀ ␀ ␀ ␀d␀i␀s␀p␀l␀a␀y␀:␀ ␀f␀l␀e␀x␀;␀
